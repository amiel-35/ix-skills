{
  "metier": [
    "rh",
    "juridique"
  ],
  "category": "production",
  "params": {
    "mode": {
      "label": "Mode",
      "type": "enum",
      "required": false,
      "default": "analyse",
      "help": "Analyser un document existant ou en generer un nouveau.",
      "values": [
        "analyse",
        "generation",
        "revision"
      ]
    },
    "type_contrat": {
      "label": "Type de contrat",
      "type": "enum",
      "required": false,
      "default": "cdi",
      "values": [
        "cdi",
        "cdd",
        "alternance",
        "stage",
        "freelance",
        "avenant"
      ]
    },
    "pays": {
      "label": "Pays applicable",
      "type": "string",
      "required": false,
      "default": "France",
      "help": "Droit applicable. Par defaut : France."
    }
  },
  "ui": {
    "simple_fields": [
      "mode",
      "type_contrat"
    ],
    "advanced_fields": [
      "pays"
    ]
  },
  "execution": {
    "supports_async": true,
    "supports_review_gate": true,
    "max_input_artifacts": 4,
    "max_estimated_tokens": 24000
  },
  "color": "#702459",
  "kind": "llm",
  "launch_mode": "run",
  "transport": "json",
  "output_format": "markdown",
  "enabled": true,
  "visibility": "public"
}
