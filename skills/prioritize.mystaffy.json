{
  "category": "decision",
  "aliases": ["prioriser"],
  "params": {
    "framework": {
      "label": "Framework",
      "type": "enum",
      "required": false,
      "default": "ice",
      "values": ["ice", "rice", "moscow", "eisenhower", "value-vs-effort", "custom"],
      "help": "Scoring framework — default: ICE (Impact · Confidence · Ease)"
    },
    "criteria": {
      "label": "Custom criteria",
      "type": "text",
      "required": false,
      "placeholder": "e.g. revenue impact, technical risk, dependency",
      "help": "Used when framework is 'custom'"
    },
    "horizon": {
      "label": "Time horizon",
      "type": "enum",
      "required": false,
      "values": ["sprint", "quarter", "year", "unspecified"],
      "default": "unspecified"
    },
    "constraints": {
      "label": "Hard constraints",
      "type": "text",
      "required": false,
      "placeholder": "e.g. regulatory deadline, blocking dependency"
    }
  },
  "ui": {
    "simple_fields": ["framework", "horizon"],
    "advanced_fields": ["criteria", "constraints"]
  },
  "execution": {
    "supports_review_gate": false,
    "max_input_artifacts": 20,
    "max_estimated_tokens": 12000
  }
}
